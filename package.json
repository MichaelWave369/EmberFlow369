{
  "name": "emberflow369",
  "version": "0.5.0-alpha.0",
  "private": false,
  "description": "Fire + Flood Resilience Mesh with action cards, receipt-ledger discipline, a local dashboard cockpit, exportable evidence bundles, and GitHub Pages deployment.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "demo": "npm run build && node dist/demo.js",
    "check": "npm run typecheck && npm run build",
    "dashboard": "npm --prefix apps/dashboard run dev",
    "dashboard:build": "npm --prefix apps/dashboard run build",
    "dashboard:preview": "npm --prefix apps/dashboard run preview"
  },
  "keywords": [
    "wildfire",
    "flood",
    "resilience",
    "receipts",
    "california",
    "emergency-preparedness",
    "dashboard",
    "github-pages"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
