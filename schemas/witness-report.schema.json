{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MichaelWave369/EmberFlow369/schemas/witness-report.schema.json",
  "title": "EmberFlow369 Witness Report",
  "type": "object",
  "required": ["id", "createdAt", "reportType", "zoneId", "summary", "confidence", "safetyAcknowledged"],
  "properties": {
    "id": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "observedAt": { "type": ["string", "null"], "format": "date-time" },
    "reportType": {
      "type": "string",
      "enum": ["smoke_visible", "flames_visible", "road_blocked", "water_over_road", "creek_rising", "culvert_blocked", "power_out", "shelter_info", "other"]
    },
    "zoneId": { "type": "string" },
    "locationPrecision": {
      "type": "string",
      "enum": ["exact_private", "approximate_public", "zone_only"]
    },
    "summary": { "type": "string" },
    "mediaIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "string",
      "enum": ["unverified", "observed", "multi-source", "official-confirmed", "stale", "superseded"]
    },
    "safetyAcknowledged": { "type": "boolean" },
    "privacyNotes": { "type": "string" },
    "receiptId": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
